          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "addSchool"
          ]
        },
        "description": "Creates a new school after validating the payload.\n\nExpected success response: 201 Created\nExpected error response: 400 Bad Request when any field is missing or invalid."
      },
      "response": []
    },
    {
      "name": "List Schools By Proximity",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/listSchools?latitude={{userLatitude}}&longitude={{userLongitude}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "listSchools"
          ],
          "query": [
            {
              "key": "latitude",
              "value": "{{userLatitude}}"
            },
            {
              "key": "longitude",
              "value": "{{userLongitude}}"
            }
          ]
        },
        "description": "Returns all schools sorted from nearest to farthest based on the user's latitude and longitude.\n\nExpected success response: 200 OK\nExpected error response: 400 Bad Request when query parameters are invalid."
      },
      "response": []
    }

          "raw": "{\n  \"name\": \"Fertilizer Public School\",\n  \"address\": \"Kribhco Shyam Nagar, Piprola, Jalalabad Road, Shahjahanpur, Uttar Pradesh\",\n  \"latitude\": 27.883743,\n  \"longitude\": 79.91225\n}\n"
